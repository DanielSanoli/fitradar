# FitRadar — variáveis de ambiente (copie para .env e ajuste)
# Nunca commite .env — ele está no .gitignore.

# --- Core ---
DATABASE_URL=jdbc:postgresql://localhost:5432/fitradar
DATABASE_USERNAME=fitradar
DATABASE_PASSWORD=fitradar
SERVER_PORT=8080
PUBLIC_BASE_URL=https://app.seudominio.com
APP_PRODUCTION=false

# --- Segurança (obrigatório em produção) ---
JWT_SECRET=troque-por-um-segredo-bem-grande-com-no-minimo-32-caracteres-aleatorios
CORS_ALLOWED_ORIGINS=https://app.seudominio.com

# --- Billing Asaas (obrigatório se ASAAS_ENABLED=true) ---
ASAAS_ENABLED=false
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_MONTHLY_PRICE=49.90
MARKETPLACE_PLATFORM_FEE_PERCENT=10.00
MARKETPLACE_PLATFORM_FEE_PERCENT_FREE=10.00
MARKETPLACE_PLATFORM_FEE_PERCENT_PRO=0.00
BILLING_FREE_MAX_STUDENTS=30
BILLING_FREE_MAX_ACTIVE_PROGRAMS=3

# --- E-mail Resend (opcional — sem chave usa log local) ---
RESEND_API_KEY=
EMAIL_FROM=FitRadar <no-reply@fitradar.app>

# --- Copiloto IA (obrigatório se COPILOT_AI_ENABLED=true) ---
COPILOT_AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Retenção / digest ---
RETENTION_TIMEZONE=America/Sao_Paulo
DIGEST_ENABLED=true

# --- Onboarding ---
DEMO_SEED_ENABLED=true

# --- PWA Push (opcional — gere par de chaves VAPID para produção) ---
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@fitradar.app
PUSH_FRONTEND_BASE_URL=http://localhost:8080

# --- Observabilidade opcional ---
# SENTRY_DSN=              # opt-in: erros 5xx vão ao Sentry quando preenchido
# SENTRY_ENVIRONMENT=production
# METRICS_ENABLED=false      # true expõe /actuator/prometheus (protegido por token)
# MANAGEMENT_TOKEN=          # obrigatório se METRICS_ENABLED=true em produção
# SWAGGER_ENABLED=true       # false em APP_PRODUCTION=true (application-prod.yml)
