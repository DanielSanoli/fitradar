# URL base da API Spring (sem barra final)
# Dev (Vite :5173 → API :8080):
VITE_API_URL=http://localhost:8080
# Build embutido no JAR / Docker (mesma origem): deixe vazio
# VITE_API_URL=

# URL pública para links compartilháveis (espaço do criador, convites)
# Dev: use a origem do Vite ou do JAR. Produção: https://fitradar.app (ou domínio do deploy)
# VITE_PUBLIC_BASE_URL=http://localhost:5173
# VITE_PUBLIC_BASE_URL=https://fitradar.app
